# =====================================================================
# HYPERSONIC - Variables de entorno
# =====================================================================
# La única variable OBLIGATORIA es DATABASE_URL (cadena de conexión a Postgres).
# El resto son opcionales.
# =====================================================================

# ---------- OBLIGATORIA ----------
# Cadena de conexión a PostgreSQL.
# En Render: te la da al crear la base de datos (Internal Database URL).
# En Neon: te la da al crear el proyecto.
# Formato: postgres://usuario:password@host:5432/nombre_db
DATABASE_URL=postgres://usuario:password@host:5432/hypersonic

# ---------- OPCIONAL ----------
# URL pública de tu app (para notificaciones push y CORS).
# En Render: https://TU_SERVICIO.onrender.com
# Si no se define, se usa automáticamente la URL del request.
# NEXT_PUBLIC_APP_URL=https://TU_SERVICIO.onrender.com

# ---------- OPCIONAL: Web Push (notificaciones cuando la app está cerrada) ----------
# Genera tus propias keys con: npx web-push generate-vapid-keys
# Si NO las configuras, las notificaciones solo funcionan con la app abierta.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:tu@email.com
